rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config (profile, links) — anyone can read, only authenticated admin can write
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Click analytics — anyone can log a click or read (for shareable analytics page)
    match /clicks/{docId} {
      allow create: if true;
      allow read: if true;
    }

    // Page view analytics — anyone can log a view or read
    match /pageviews/{docId} {
      allow create: if true;
      allow read: if true;
    }

    // Email subscribers — anyone can subscribe or unsubscribe, only John can read the list
    match /subscribers/{doc} {
      allow create, delete: if true;
      allow read, list: if request.auth != null
        && request.auth.token.email == "johneilcarltagudin@gmail.com";
    }

    // Reviews — anyone can submit or read, only John can approve/reject/delete
    match /reviews/{doc} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null
        && request.auth.token.email == "johneilcarltagudin@gmail.com";
    }
  }
}
