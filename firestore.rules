rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config (profile, links) — anyone can read, only authenticated admin can write
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Click analytics — anyone can log a click, only authenticated admin can read
    match /clicks/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
